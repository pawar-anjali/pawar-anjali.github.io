---
import { siteConfig } from "../config";
---
<section id="about" class="px-8 py-16 sm:px-12 sm:py-20 md:px-24 md:py-24">
  <h2 class="text-3xl sm:text-4xl md:text-5xl font-bold text-gray-900 mb-2">About Me</h2>
  <div class="w-16 h-1 rounded-full mb-10" style={`background-color: ${siteConfig.accentColor}`}></div>
  <p class="text-lg sm:text-xl md:text-2xl leading-relaxed text-gray-600 mb-10">
    {siteConfig.aboutMe}
  </p>
  <div class="flex flex-wrap gap-3">
    {siteConfig.skills.map((skill) => (
      <span class="px-4 py-2 bg-gray-100 text-gray-800 rounded-full text-sm sm:text-base font-medium hover:bg-gray-200 transition-colors duration-200">
        {skill}
      </span>
    ))}
  </div>
</section>
