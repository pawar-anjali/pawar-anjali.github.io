---
import { siteConfig } from "../config";
const hasCertifications = siteConfig.certifications && siteConfig.certifications.length > 0;
---
{hasCertifications && (
  <section id="certifications" class="px-8 py-16 sm:px-12 sm:py-20 md:px-24 md:py-24">
    <h2 class="text-3xl sm:text-4xl md:text-5xl font-bold text-gray-900 mb-2">Certifications</h2>
    <div class="w-16 h-1 rounded-full mb-10" style={`background-color: ${siteConfig.accentColor}`}></div>
    <div class="space-y-6">
      {siteConfig.certifications.map((cert) => (
        <div class="bg-white rounded-lg shadow-sm border border-gray-100 p-5 md:p-6 hover:shadow-md transition-shadow duration-300">
          <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between mb-2">
            <div>
              <h3 class="text-lg sm:text-xl font-semibold text-gray-900">{cert.degree}</h3>
              <p class="text-base sm:text-lg" style={`color: ${siteConfig.accentColor}`}>{cert.school}</p>
            </div>
            <span class="text-xs sm:text-sm text-gray-500 mt-2 sm:mt-0 sm:ml-4 whitespace-nowrap">{cert.dateRange}</span>
          </div>
          <ul class="space-y-1 mt-2">
            {cert.achievements.map((achievement) => (
              <li class="flex items-start">
                <span class="inline-block w-1.5 h-1.5 rounded-full bg-gray-400 mt-2 mr-3 flex-shrink-0" />
                <span class="text-sm sm:text-base text-gray-600">{achievement}</span>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </section>
)}
